//-----------------------------------------------------------------------------

uniform vec2	crtOverscan = vec2 ( 1.0 );

vec2 overscan ( vec2 uv )
{
	// 0 to 1 -> -1 to +1
	vec2	ouv = ( uv - 0.5 ) * 2.0;

	// Scale
	ouv *= crtOverscan;

	// -1 to + 1 -> 0 to 1
	ouv  = ( ouv / 2.0 ) + 0.5;

	return ouv;
}
