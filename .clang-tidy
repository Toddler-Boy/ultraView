Checks: '*, -clang-diagnostic-c++98-*, -clang-diagnostic-pre-c++14-*, -clang-diagnostic-pre-c++17-*, -clang-diagnostic-pre-c++20-compat, -boost-*, -llvmlibc-*, -cppcoreguidelines-*, -cert-*, -altera-*, -google-*, -fuchsia-*, -hicpp-*, -portability-*, -clang-diagnostic-old-style-cast, -misc-include-cleaner, -misc-non-private-member-variables-in-classes, -modernize-use-trailing-return-type, -readability-braces-around-statements, -readability-avoid-const-params-in-decls, -readability-identifier-length, -readability-uppercase-literal-suffix, -clang-diagnostic-unsafe-buffer-usage, -llvm-header-guard, -llvm-qualified-auto, -readability-qualified-auto, -readability-implicit-bool-conversion, -readability-function-cognitive-complexity, -modernize-use-integer-sign-comparison, -clang-diagnostic-sign-conversion, -modernize-use-designated-initializers, -modernize-avoid-c-arrays, -readability-magic-numbers, -readability-math-missing-parentheses, -bugprone-implicit-widening-of-multiplication-result, -bugprone-easily-swappable-parameters, -bugprone-narrowing-conversions, -bugprone-switch-missing-default-case, -misc-use-internal-linkage, -bugprone-exception-escape, -bugprone-inc-dec-in-conditions'
WarningsAsErrors: ''
